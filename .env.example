# One key fallback for local development
GEMINI_API_KEY=

# Multiple system keys. Comma-separated (e.g. key1,key2,key3).
# Prefer keys from separate Google Cloud/AI Studio projects if your goal is to distribute quota/rate-limits.
# Gemini rate limits are applied per project, not per API key.
GEMINI_API_KEYS=

GEMINI_DEFAULT_MODEL=gemini-3.1-flash-lite
