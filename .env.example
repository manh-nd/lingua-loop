
# Multiple system keys. Comma-separated (e.g. key1,key2,key3).
# GEMINI_API_KEYS is comma-separated. For effective quota distribution, use keys from separate projects you own. Multiple keys from the same project may still share the same project-level quota.
GEMINI_API_KEYS=

GEMINI_DEFAULT_MODEL=gemini-3.1-flash-lite

# Database Configuration
DATABASE_URL=postgres://postgres:password@localhost:5432/lingualoop

# Better Auth Configuration
BETTER_AUTH_SECRET=some_secret_key
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
